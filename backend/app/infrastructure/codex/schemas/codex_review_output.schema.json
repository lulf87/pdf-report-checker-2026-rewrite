{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://report-checker.local/schemas/codex_review_output.schema.json",
  "title": "CodexReviewOutput",
  "type": "object",
  "required": [
    "schema_version",
    "reviews"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "target_id",
          "status",
          "verdict",
          "confidence",
          "reasoning_summary",
          "evidence_refs",
          "suggested_severity",
          "suggested_finding",
          "metadata"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "succeeded"
            ]
          },
          "verdict": {
            "type": "string",
            "enum": [
              "confirm",
              "refute",
              "uncertain",
              "add_finding"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "reasoning_summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "suggested_severity": {
            "type": [
              "string",
              "null"
            ]
          },
          "suggested_finding": {
            "anyOf": [
              {
                "$ref": "#/$defs/suggested_finding"
              },
              {
                "type": "null"
              }
            ]
          },
          "metadata": {
            "type": "object"
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "verdict": {
                  "const": "add_finding"
                }
              },
              "required": [
                "verdict"
              ]
            },
            "then": {
              "properties": {
                "suggested_finding": {
                  "$ref": "#/$defs/suggested_finding"
                }
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "suggested_finding": {
      "type": "object",
      "required": [
        "check_id",
        "severity",
        "code",
        "message",
        "expected",
        "actual",
        "evidence_refs",
        "metadata"
      ],
      "properties": {
        "check_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "severity": {
          "type": [
            "string",
            "null"
          ]
        },
        "code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "type": [
            "string",
            "null"
          ]
        },
        "actual": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  }
}
